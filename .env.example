# Required: Lexware Office API key (from Lexware Office → Einstellungen → API)
LEXWARE_OFFICE_API_KEY=your-api-key-here

# Governance / Safety Mode
# Options: safe (default) | standard | unrestricted | custom
# safe:         No finalization, no deletions (except event subscriptions). AI can only create/read/edit drafts.
# standard:     Finalization allowed, no deletions.
# unrestricted: All classic operations allowed. Draft-numbered document deletion still requires explicit opt-in.
# custom:       Start from safe defaults and apply individual LEXWARE_PERMISSIONS_* overrides below.
LEXWARE_SAFETY_MODE=safe

# Fine-grained permission overrides (override the preset for individual actions)
# These take effect regardless of LEXWARE_SAFETY_MODE.
# LEXWARE_PERMISSIONS_FINALIZE_INVOICES=false
# LEXWARE_PERMISSIONS_FINALIZE_QUOTATIONS=false
# LEXWARE_PERMISSIONS_FINALIZE_CREDIT_NOTES=false
# LEXWARE_PERMISSIONS_FINALIZE_ORDER_CONFIRMATIONS=false
# LEXWARE_PERMISSIONS_FINALIZE_DELIVERY_NOTES=false
# LEXWARE_PERMISSIONS_FINALIZE_DUNNINGS=false
# LEXWARE_PERMISSIONS_DELETE_ARTICLES=false
# LEXWARE_PERMISSIONS_DELETE_CONTACTS=false
# LEXWARE_PERMISSIONS_DELETE_VOUCHERS=false
# LEXWARE_PERMISSIONS_DELETE_EVENT_SUBSCRIPTIONS=true
# LEXWARE_PERMISSIONS_ARCHIVE_CONTACTS=true
# LEXWARE_PERMISSIONS_ARCHIVE_ARTICLES=true

# Draft-numbered document deletion (creates gaps in sequential numbering — use with extreme caution)
# Not enabled by any preset, requires explicit opt-in:
# LEXWARE_PERMISSIONS_DELETE_INVOICE_DRAFTS=false
# LEXWARE_PERMISSIONS_DELETE_QUOTATION_DRAFTS=false
# LEXWARE_PERMISSIONS_DELETE_CREDIT_NOTE_DRAFTS=false
# LEXWARE_PERMISSIONS_DELETE_ORDER_CONFIRMATION_DRAFTS=false
# LEXWARE_PERMISSIONS_DELETE_DELIVERY_NOTE_DRAFTS=false

# Audit log path (optional — log all allow decisions to this file)
# LEXWARE_AUDIT_LOG_PATH=/var/log/lexware-mcp-audit.log
